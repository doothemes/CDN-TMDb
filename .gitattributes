# Normalizar saltos de línea
* text=auto

# PHP
*.php text eol=lf

# Apache
.htaccess text eol=lf

# Documentación
*.md text eol=lf
LICENSE text eol=lf

# Configuración
.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Exportar: excluir del zip de release (gh release, git archive)
*.md export-ignore
.gitignore export-ignore
.gitattributes export-ignore
