# Clave secreta para endpoints administrativos (get_stats, cleaner)
# Si se deja vacía, los endpoints admin rechazan todas las peticiones
API_SECRET=cambiar-esta-clave-en-produccion

# Días máximos que una imagen puede estar sin ser consultada antes de ser eliminada por el cron
MAX_INACTIVE_DAYS=30

# Origen permitido para CORS. Usa "*" para abierto, o un dominio específico
CORS_ORIGIN=*

# TTL del negative cache (segundos). Tiempo que se recuerda un 404 de TMDB
# para evitar golpear repetidamente el upstream con hashes inválidos
NEGATIVE_CACHE_TTL=3600

# Pool de IPs de Googlebot para rotar en X-Forwarded-For (CSV)
# Si se comenta, se usa un pool por defecto hardcodeado
GOOGLEBOT_IPS=66.249.66.1,66.249.66.12,66.249.66.33,66.249.66.45,66.249.66.68,66.249.66.79,66.249.66.82,66.249.66.91,66.249.66.104
